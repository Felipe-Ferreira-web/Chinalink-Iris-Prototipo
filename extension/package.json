{
  "name": "iris-extension",
  "version": "0.1.0",
  "description": "Extensão Iris: revela e extrai o contato do fornecedor na página, repassa para o hub",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.5.4",
    "wxt": "^0.20.27"
  }
}
