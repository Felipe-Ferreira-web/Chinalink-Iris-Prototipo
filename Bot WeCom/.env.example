# Título da janela principal do WeChat desktop — varia entre sessões
# ("Weixin"/"WeChat", confirmado ao vivo), por isso as duas alternativas
# separadas por "|". Não usar WM_CLASS: casa com várias sub-janelas menores
# (tooltips, ícone de bandeja etc.).
WECHAT_WINDOW_NAME=WeChat|Weixin

# Nome exato (como aparece na sidebar) da conversa usada nos testes de envio
# (--test-reply). Use algo seguro pra teste, ex.: "File Transfer" (canal de
# notas pessoais do próprio WeChat) — não um contato real.
TARGET_CHAT_NAME=File Transfer

LOG_LEVEL=INFO

# URL do server Django do módulo "Busca de Suppliers" — usado por
# sync_suppliers.py pra buscar fornecedores com contato_extraido e marcar
# contato_wechat_enviado depois de tentar o pedido de amizade.
SOURCING_SERVER_URL=http://localhost:8000

# Mensagem fixa enviada como verificação do pedido de amizade (sem IA por
# enquanto, ver FLUXO.md).
WECHAT_WELCOME_MESSAGE=Olá! Somos da Chinalink, temos interesse nos seus produtos.

# Intervalo (segundos) entre consultas ao server em sync_suppliers.py.
SYNC_INTERVAL_SECONDS=30
