# Título da janela principal do WeChat desktop — varia entre sessões
# ("Weixin"/"WeChat", confirmado ao vivo), por isso as duas alternativas
# separadas por "|". Não usar WM_CLASS: casa com várias sub-janelas menores
# (tooltips, ícone de bandeja etc.).
WECHAT_WINDOW_NAME=WeChat|Weixin

# Nome exato (como aparece na sidebar) da conversa usada nos testes de envio
# (--test-reply). Use algo seguro pra teste, ex.: "File Transfer" (canal de
# notas pessoais do próprio WeChat) — não um contato real.
TARGET_CHAT_NAME=File Transfer

LOG_LEVEL=INFO
