# Nome exato (como aparece na sidebar) da conversa usada nos testes.
# Use algo seguro, ex.: "File Transfer" (canal de notas pessoais do
# próprio WeChat) — não um contato real.
TARGET_CHAT_NAME=File Transfer

# Mensagem de teste enviada por main.py --test-reply.
TEST_MESSAGE=teste automação

# Quantos segundos main.py fica escutando TARGET_CHAT_NAME antes de sair
# sozinho (evita loop infinito acidental num primeiro teste manual).
LISTEN_DURATION_SECONDS=30

LOG_LEVEL=INFO

# URL do server Django do módulo "Busca de Suppliers" — nesta etapa roda
# na MESMA máquina que este bot (sem CORS/rede entre servidores).
SOURCING_SERVER_URL=http://localhost:8000

# Intervalo (segundos) entre consultas ao server em sync_suppliers.py.
SYNC_INTERVAL_SECONDS=30

# Telefone usado só por `sync_suppliers.py --test-phone`, pra testar o
# fluxo de adicionar contato isolado, sem precisar do server. Preencha na
# hora do teste com um número real que vá ACEITAR o pedido de amizade
# rápido (colega de equipe avisado, ou um segundo dispositivo seu) — sem
# aceite, não existe conversa pra mandar a mensagem de boas-vindas.
TEST_PHONE=18620884266

# Mensagem de boas-vindas enviada ao fornecedor logo após adicioná-lo
# (sem IA por enquanto).
WECHAT_WELCOME_MESSAGE=Olá! Tenho interesse em importar produtos da China, Podemos iniciar contato?
