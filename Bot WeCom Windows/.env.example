# Nome exato (como aparece na sidebar) da conversa usada nos testes.
# Use algo seguro, ex.: "File Transfer" (canal de notas pessoais do
# próprio WeChat) — não um contato real.
TARGET_CHAT_NAME=File Transfer

# Mensagem de teste enviada por main.py --test-reply.
TEST_MESSAGE=teste wxauto4

# Quantos segundos main.py fica escutando TARGET_CHAT_NAME antes de sair
# sozinho (evita loop infinito acidental num primeiro teste manual).
LISTEN_DURATION_SECONDS=30

LOG_LEVEL=INFO
